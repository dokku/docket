- name: <<yamlStr .Name>>
  inputs:
    - name: app
      default: <<yamlStr .Name>>
      description: "Application name"
    - name: repo
      <<if .Repo>>default: "<<.Repo>>"<<else>>required: true<<end>>
      description: "Git repository URL"
  tasks:
    - name: create app
      dokku_app:
        app: "{{ .app | dq }}"
        state: present

    - name: configure env vars
      dokku_config:
        app: "{{ .app | dq }}"
        config:
          APP_ENV: production
          LOG_LEVEL: info

    - name: configure domains
      dokku_domains:
        app: "{{ .app | dq }}"
        domains: ["{{ .app | dq }}.example.com"]
        state: set

    - name: sync git repository
      dokku_git_sync:
        app: "{{ .app | dq }}"
        remote: "{{ .repo | dq }}"
